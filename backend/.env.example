# ============================================================
#  COD1 ECOSYSTEM — ENVIRONMENT VARIABLES
#  NEVER commit this file to GitHub. Add .env to .gitignore
# ============================================================

# Your Gmail address
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular password)
# Get it: myaccount.google.com → Security → App Passwords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Your site's public URL (use Render URL after deploying)
BASE_URL=https://your-app.onrender.com

# Frontend URL (same as BASE_URL for production)
FRONTEND_URL=https://your-app.onrender.com

# Twilio (for real SMS OTP)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1xxxxxxxxxx

# Secret for JWT tokens (make it long and random)
JWT_SECRET=make_this_very_long_and_random_like_64_chars_minimum
